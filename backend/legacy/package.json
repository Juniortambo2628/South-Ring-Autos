{
  "name": "south-ring-autos",
  "version": "1.0.0",
  "description": "South Ring Autos Website - Asset bundling and build tools",
  "scripts": {
    "build": "webpack --mode production",
    "build:prod": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "minify-css": "postcss css/*.css --dir css/dist --use autoprefixer cssnano",
    "lint-js": "eslint js/**/*.js",
    "format-js": "prettier --write js/**/*.js",
    "pre-deploy": "npm run build && composer install --no-dev --optimize-autoloader"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.52.0",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.0.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "filepond": "^4.32.10",
    "filepond-plugin-file-validate-size": "^2.2.8",
    "filepond-plugin-file-validate-type": "^1.2.9",
    "filepond-plugin-image-preview": "^4.6.12",
    "filepond-plugin-image-resize": "^2.0.10",
    "fuse.js": "^7.1.0",
    "gridjs": "^6.2.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "right-click-menu": "^0.0.4",
    "swiper": "^11.0.0",
    "toastr": "^2.1.4",
    "validator": "^13.15.23"
  }
}
